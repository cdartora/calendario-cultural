# Variáveis de ambiente para Google Sheets API
# Obtenha estas credenciais criando um Service Account no Google Cloud Console
# 1. Vá para https://console.cloud.google.com/
# 2. Crie um novo projeto ou selecione um existente
# 3. Habilite a Google Sheets API
# 4. Crie credenciais do tipo "Service Account"
# 5. Baixe o arquivo JSON e extraia os valores abaixo

GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_CLIENT_EMAIL="seu-service-account@seu-projeto.iam.gserviceaccount.com"
GOOGLE_SHEETS_SPREADSHEET_ID="ID_DA_SUA_PLANILHA"

# O ID da planilha pode ser encontrado na URL:
# https://docs.google.com/spreadsheets/d/[ESTE_É_O_ID]/edit
